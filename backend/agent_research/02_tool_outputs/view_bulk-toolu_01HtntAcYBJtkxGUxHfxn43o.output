32|# -------------------- Auth utils --------------------
33|JWT_ALGO = "HS256"
34|
35|def jwt_secret() -> str:
36|    return os.environ["JWT_SECRET"]
37|
38|def hash_password(pw: str) -> str:
39|    return bcrypt.hashpw(pw.encode(), bcrypt.gensalt()).decode()
40|
41|def verify_password(pw: str, hashed: str) -> bool:
42|    try:
43|        return bcrypt.checkpw(pw.encode(), hashed.encode())
44|    except Exception:
45|        return False
46|
47|def make_access_token(user_id: str, email: str) -> str:
48|    payload = {"sub": user_id, "email": email,
49|               "exp": datetime.now(timezone.utc) + timedelta(hours=12),
50|               "type": "access"}
51|    return jwt.encode(payload, jwt_secret(), algorithm=JWT_ALGO)
52|
53|def make_refresh_token(user_id: str) -> str:
54|    payload = {"sub": user_id,
55|               "exp": datetime.now(timezone.utc) + timedelta(days=7),
56|               "type": "refresh"}
57|    return jwt.encode(payload, jwt_secret(), algorithm=JWT_ALGO)
58|
59|def set_auth_cookies(resp: Response, access: str, refresh: str):
60|    resp.set_cookie("access_token", access, httponly=True, secure=False, samesite="lax",
61|                    max_age=12 * 3600, path="/")
62|    resp.set_cookie("refresh_token", refresh, httponly=True, secure=False, samesite="lax",
63|                    max_age=7 * 24 * 3600, path="/")
64|
65|async def get_current_user(request: Request) -> dict:
66|    token = request.cookies.get("access_token")
67|    if not token:
68|        auth = request.headers.get("Authorization", "")
69|        if auth.startswith("Bearer "):
70|            token = auth[7:]
71|    if not token:
72|        raise HTTPException(401, "Not authenticated")
73|    try:
74|        payload = jwt.decode(token, jwt_secret(), algorithms=[JWT_ALGO])
75|        if payload.get("type") != "access":
76|            raise HTTPException(401, "Invalid token type")
77|        user = await db.users.find_one({"id": payload["sub"]}, {"_id": 0, "password_hash": 0})
78|        if not user:
79|            raise HTTPException(401, "User not found")
80|        return user
81|    except jwt.ExpiredSignatureError:
82|        raise HTTPException(401, "Token expired")
83|    except jwt.InvalidTokenError:
84|        raise HTTPException(401, "Invalid token")
