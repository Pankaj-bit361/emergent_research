182|# -------------------- Auth Endpoints --------------------
183|@api.post("/auth/register", response_model=UserOut)
184|async def register(payload: RegisterIn, response: Response):
185|    email = payload.email.lower()
186|    if await db.users.find_one({"email": email}):
187|        raise HTTPException(400, "Email already registered")
188|    user = {
189|        "id": new_id(),
190|        "name": payload.name,
191|        "email": email,
192|        "password_hash": hash_password(payload.password),
193|        "role": "user",
194|        "created_at": now_iso(),
195|    }
196|    await db.users.insert_one(user)
197|    set_auth_cookies(response, make_access_token(user["id"], email), make_refresh_token(user["id"]))
198|    return UserOut(**{k: v for k, v in user.items() if k != "password_hash"})
199|
200|@api.post("/auth/login", response_model=UserOut)
201|async def login(payload: LoginIn, response: Response):
202|    email = payload.email.lower()
203|    user = await db.users.find_one({"email": email})
204|    if not user or not verify_password(payload.password, user["password_hash"]):
205|        raise HTTPException(401, "Invalid email or password")
206|    set_auth_cookies(response, make_access_token(user["id"], email), make_refresh_token(user["id"]))
207|    user = strip_mongo(user)
208|    user.pop("password_hash", None)
209|    return UserOut(**user)
210|
211|@api.post("/auth/logout")
212|async def logout(response: Response):
213|    response.delete_cookie("access_token", path="/")
214|    response.delete_cookie("refresh_token", path="/")
215|    return {"ok": True}
216|
217|@api.get("/auth/me", response_model=UserOut)
218|async def me(current=Depends(get_current_user)):
219|    return UserOut(**current)
220|
221|@api.post("/auth/refresh")
222|async def refresh_token(request: Request, response: Response):
223|    rt = request.cookies.get("refresh_token")
224|    if not rt:
225|        raise HTTPException(401, "No refresh token")
226|    try:
227|        payload = jwt.decode(rt, jwt_secret(), algorithms=[JWT_ALGO])
228|        if payload.get("type") != "refresh":
229|            raise HTTPException(401, "Invalid token")
230|        user = await db.users.find_one({"id": payload["sub"]})
231|        if not user:
232|            raise HTTPException(401, "User not found")
233|        set_auth_cookies(response, make_access_token(user["id"], user["email"]), rt)
234|        return {"ok": True}
235|    except jwt.InvalidTokenError:
236|        raise HTTPException(401, "Invalid refresh token")
