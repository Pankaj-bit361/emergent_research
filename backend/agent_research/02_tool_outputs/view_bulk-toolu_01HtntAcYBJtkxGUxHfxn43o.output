425|# -------------------- AI --------------------
426|class LeadScoreIn(BaseModel):
427|    contact_id: str
428|
429|class EmailDraftIn(BaseModel):
430|    contact_id: Optional[str] = None
431|    deal_id: Optional[str] = None
432|    purpose: str = "follow-up"
433|    tone: str = "friendly professional"
434|    context: Optional[str] = None
435|
436|async def _llm_chat(system: str, user_text: str) -> str:
437|    from emergentintegrations.llm.chat import LlmChat, UserMessage
438|    key = os.environ["EMERGENT_LLM_KEY"]
439|    chat = LlmChat(
440|        api_key=key,
441|        session_id=f"crm-{uuid.uuid4()}",
442|        system_message=system,
443|    ).with_model("anthropic", "claude-sonnet-4-5-20250929")
444|    resp = await chat.send_message(UserMessage(text=user_text))
445|    return str(resp)
446|
447|@api.post("/ai/lead-score")
448|async def ai_lead_score(payload: LeadScoreIn, current=Depends(get_current_user)):
449|    contact = await db.contacts.find_one({"id": payload.contact_id}, {"_id": 0})
450|    if not contact:
451|        raise HTTPException(404, "Contact not found")
452|    deals = await db.deals.find({"contact_id": payload.contact_id}, {"_id": 0}).to_list(50)
453|    notes = await db.notes.find({"contact_id": payload.contact_id}, {"_id": 0}).sort("created_at", -1).limit(10).to_list(10)
454|
455|    system = (
456|        "You are a senior sales operations analyst. Given a CRM contact, related deals and notes, "
457|        "produce a lead score from 0 to 100 and a short reasoning (max 3 sentences). "
458|        "Respond in STRICT JSON ONLY with the shape: {\"score\": <int>, \"reasoning\": \"<text>\"}. "
459|        "No prose, no markdown, no backticks."
460|    )
461|    user_text = (
462|        f"Contact:\n{contact}\n\nDeals:\n{deals}\n\nRecent notes:\n{notes}\n\n"
463|        "Score this lead based on engagement, deal value, status, and recent activity."
464|    )
465|    raw = await _llm_chat(system, user_text)
466|    import json, re
467|    score = 50
468|    reasoning = raw.strip()
469|    try:
470|        m = re.search(r"\{[\s\S]*\}", raw)
471|        if m:
472|            data = json.loads(m.group(0))
473|            score = int(data.get("score", 50))
474|            reasoning = data.get("reasoning", reasoning)
475|    except Exception as e:
476|        logger.warning(f"lead-score parse failed: {e}")
477|    score = max(0, min(100, score))
478|    await db.contacts.update_one({"id": payload.contact_id},
479|                                 {"$set": {"lead_score": score, "score_reasoning": reasoning}})
480|    return {"score": score, "reasoning": reasoning}
481|
482|@api.post("/ai/email-draft")
483|async def ai_email_draft(payload: EmailDraftIn, current=Depends(get_current_user)):
484|    contact = None
485|    deal = None
486|    if payload.contact_id:
487|        contact = await db.contacts.find_one({"id": payload.contact_id}, {"_id": 0})
488|    if payload.deal_id:
489|        deal = await db.deals.find_one({"id": payload.deal_id}, {"_id": 0})
490|
491|    system = (
492|        "You are an expert B2B sales writer. Draft concise, warm, high-converting emails. "
493|        "Output a JSON object with keys 'subject' and 'body' ONLY. No markdown, no backticks."
494|    )
495|    user_text = (
496|        f"Purpose: {payload.purpose}\nTone: {payload.tone}\n"
497|        f"Sender: {current.get('name','Sales')}\n"
498|        f"Contact: {contact}\nDeal: {deal}\n"
499|        f"Additional context: {payload.context or 'none'}\n"
500|        "Return JSON: {\"subject\": \"...\", \"body\": \"...\"}"
501|    )
502|    raw = await _llm_chat(system, user_text)
503|    import json, re
504|    subject = "Following up"
505|    body = raw.strip()
506|    try:
507|        m = re.search(r"\{[\s\S]*\}", raw)
508|        if m:
509|            data = json.loads(m.group(0))
510|            subject = data.get("subject", subject)
511|            body = data.get("body", body)
512|    except Exception as e:
513|        logger.warning(f"email-draft parse failed: {e}")
514|    return {"subject": subject, "body": body}
