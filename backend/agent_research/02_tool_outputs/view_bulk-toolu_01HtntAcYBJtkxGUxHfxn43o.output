376|# -------------------- Dashboard --------------------
377|@api.get("/dashboard/stats")
378|async def dashboard_stats(current=Depends(get_current_user)):
379|    contacts_total = await db.contacts.count_documents({})
380|    deals = await db.deals.find({}, {"_id": 0}).to_list(2000)
381|    tasks_open = await db.tasks.count_documents({"completed": False})
382|    won = [d for d in deals if d["stage"] == "won"]
383|    pipeline = [d for d in deals if d["stage"] not in ("won", "lost")]
384|    revenue = sum(d.get("value", 0) for d in won)
385|    pipeline_value = sum(d.get("value", 0) for d in pipeline)
386|
387|    stage_breakdown = {}
388|    for s in ["lead", "qualified", "proposal", "negotiation", "won", "lost"]:
389|        stage_breakdown[s] = {
390|            "count": sum(1 for d in deals if d["stage"] == s),
391|            "value": sum(d.get("value", 0) for d in deals if d["stage"] == s),
392|        }
393|
394|    # Revenue trend last 6 months
395|    months = []
396|    now = datetime.now(timezone.utc).replace(day=1)
397|    for i in range(5, -1, -1):
398|        m = now - timedelta(days=30 * i)
399|        months.append({"label": m.strftime("%b"), "month": m.strftime("%Y-%m"), "value": 0})
400|    by_month = {m["month"]: m for m in months}
401|    for d in won:
402|        try:
403|            dt = datetime.fromisoformat(d["created_at"])
404|            key = dt.strftime("%Y-%m")
405|            if key in by_month:
406|                by_month[key]["value"] += d.get("value", 0)
407|        except Exception:
408|            pass
409|
410|    recent = await db.contacts.find({}, {"_id": 0}).sort("created_at", -1).limit(5).to_list(5)
411|
412|    return {
413|        "kpis": {
414|            "revenue": revenue,
415|            "deals_won": len(won),
416|            "pipeline_value": pipeline_value,
417|            "contacts": contacts_total,
418|            "tasks_open": tasks_open,
419|        },
420|        "stage_breakdown": stage_breakdown,
421|        "revenue_trend": months,
422|        "recent_contacts": recent,
423|    }
