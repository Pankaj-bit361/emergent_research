517|async def seed_admin():
518|    email = os.environ.get("ADMIN_EMAIL", "admin@crm.com").lower()
519|    pw = os.environ.get("ADMIN_PASSWORD", "admin123")
520|    existing = await db.users.find_one({"email": email})
521|    if not existing:
522|        await db.users.insert_one({
523|            "id": new_id(),
524|            "name": "Admin",
525|            "email": email,
526|            "password_hash": hash_password(pw),
527|            "role": "admin",
528|            "created_at": now_iso(),
529|        })
530|        logger.info(f"Seeded admin user {email}")
531|    elif not verify_password(pw, existing["password_hash"]):
532|        await db.users.update_one({"email": email},
533|                                  {"$set": {"password_hash": hash_password(pw)}})
