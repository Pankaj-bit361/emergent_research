173|# -------------------- Helpers --------------------
174|def new_id() -> str:
175|    return str(uuid.uuid4())
176|
177|def strip_mongo(doc):
178|    if doc and "_id" in doc:
179|        doc.pop("_id", None)
180|    return doc
